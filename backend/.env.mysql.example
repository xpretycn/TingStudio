# TingStudio 后端环境配置 - MySQL 版本

# 服务端口
PORT=3000
NODE_ENV=development

# 数据库配置
DB_TYPE=mysql
DB_PATH=./data/tingstudio.db

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=tingstudio
MYSQL_CONNECTION_LIMIT=10
MYSQL_ACQUIRE_TIMEOUT=60000
MYSQL_TIMEOUT=60000

# JWT 配置
JWT_SECRET=tingstudio_jwt_secret_key_2024
JWT_EXPIRES_IN=7d

# 上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# AI 服务配置
AI_DASHSCOPE_API_KEY=your_dashscope_api_key
AI_DASHSCOPE_MODEL=qwen-plus
AI_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

AI_ZHIPU_API_KEY=your_zhipu_api_key
AI_ZHIPU_MODEL=glm-4v-flash
AI_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

AI_DEEPSEEK_API_KEY=your_deepseek_api_key
AI_DEEPSEEK_MODEL=deepseek-chat
AI_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

AI_TIMEOUT=120000
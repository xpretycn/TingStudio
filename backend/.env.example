# TingStudio 后端环境配置

# 服务端口
PORT=3000
NODE_ENV=development

# MySQL 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=tingstudio

# JWT 配置
JWT_SECRET=tingstudio_jwt_secret_key_2024
JWT_EXPIRES_IN=7d

# 上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# CORS 配置
CORS_ORIGIN=http://localhost:5173

# TingStudio AI Agent Backend - Environment Configuration

# Server
PORT=3001
NODE_ENV=development

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# AI Service Keys (Optional - for LLM integration)
AI_DASHSCOPE_API_KEY=
AI_DASHSCOPE_MODEL=qwen-plus
AI_DASHSCOPE_VISION_MODEL=qwen-vl-plus

AI_ZHIPU_API_KEY=
AI_ZHIPU_MODEL=glm-4-flash
AI_ZHIPU_VISION_MODEL=glm-4v-flash

AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_MODEL=deepseek-chat

# Database (if needed for future persistence)
DATABASE_URL=./data/tingstudio.db

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_MAX=10
CHAT_RATE_LIMIT_WINDOW_MS=60000

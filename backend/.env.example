# TingStudio AI Agent Backend - Environment Configuration

# ═══════════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development

# ═══════════════════════════════════════════════════════
# Security (⚠️ 生产环境必须修改！)
# ═══════════════════════════════════════════════════════
# 生成强随机字符串: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS 允许的源（多个用逗号分隔）
# 开发环境
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
# 生产环境示例:
# CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# ═══════════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════════
# 数据库类型: sqlite (开发) / mysql (生产)
DB_TYPE=sqlite
DB_PATH=./data/tingstudio.db

# MySQL 配置 (DB_TYPE=mysql 时使用)
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=tingstudio
# MYSQL_PASSWORD=your-mysql-password
# MYSQL_DATABASE=tingstudio
# MYSQL_CONNECTION_LIMIT=10

# ═══════════════════════════════════════════════════════
# AI Service Keys (可选 - LLM 集成)
# ═══════════════════════════════════════════════════════
AI_DASHSCOPE_API_KEY=
AI_DASHSCOPE_MODEL=qwen-plus
AI_DASHSCOPE_VISION_MODEL=qwen-vl-plus

AI_ZHIPU_API_KEY=
AI_ZHIPU_MODEL=glm-4-flash
AI_ZHIPU_VISION_MODEL=glm-4v-flash

AI_DEEPSEEK_API_KEY=
AI_DEEPSEEK_MODEL=deepseek-chat

# ═══════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════
LOG_LEVEL=info
LOG_FORMAT=json

# ═══════════════════════════════════════════════════════
# Rate Limiting
# ═══════════════════════════════════════════════════════
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_MAX=10
CHAT_RATE_LIMIT_WINDOW_MS=60000

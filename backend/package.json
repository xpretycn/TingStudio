{
  "name": "tingstudio-backend",
  "version": "2.0.0",
  "description": "TingStudio 后端服务 - 食品配方工作数据管理平台",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:deploy": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outdir=dist --external:sql.js --external:express --external:cors --external:jsonwebtoken --external:bcryptjs --external:helmet --external:compression --external:morgan --external:multer --external:pdfkit --external:xlsx --external:express-rate-limit --external:dotenv --entry-names=[dir]/[name].js",
    "build:scf": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outdir=scf/dist --external:sql.js --external:express --external:cors --external:jsonwebtoken --external:bcryptjs --external:helmet --external:compression --external:morgan --external:multer --external:pdfkit --external:xlsx --external:express-rate-limit --external:dotenv --external:mysql2 --entry-names=[dir]/[name].js",
    "start": "node dist/index.js",
    "init-db": "tsx src/scripts/initDatabase.ts",
    "seed": "tsx src/scripts/seedData.ts",
    "import-nutrition": "tsx src/scripts/importNutritionData.ts",
    "test-mysql": "tsx src/scripts/test-mysql-connection.ts",
    "init-mysql": "tsx src/scripts/init-mysql-database.ts",
    "migrate-to-mysql": "tsx src/scripts/migrate-to-mysql.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "sync-seeds": "node src/data/nutrition-seeds/sync-seed-data.cjs"
  },
  "dependencies": {
    "@types/node-cron": "^3.0.11",
    "axios": "^1.15.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.4",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.18.0",
    "pinyin-pro": "^3.28.1",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2",
    "vitest": "^4.1.5",
    "zod": "^4.4.3"
  }
}

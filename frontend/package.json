{
  "name": "tingstudio-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:deploy": "vite build",
    "preview": "vite preview",
    "init:sample-data": "tsx scripts/initSampleData.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "echarts": "^6.0.0",
    "marked": "^18.0.3",
    "pinia": "^2.1.7",
    "tdesign-vue-next": "^1.9.6",
    "vee-validate": "^4.12.8",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "xlsx": "^0.18.5",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "msw": "^2.13.4",
    "sass": "^1.72.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.1.4",
    "vue-tsc": "^2.0.6"
  }
}
